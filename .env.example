# 공공데이터포털 인증키 (필수)
# https://www.data.go.kr 에서 "국토교통부 아파트매매 실거래자료" 활용신청
DATA_GO_KR_API_KEY=여기에_디코딩된_인증키_붙여넣기

# 카카오 REST API 키 (선택 - 입지 분석용)
KAKAO_REST_API_KEY=

# VWorld 인증키 (선택 - 토지/용도지역)
VWORLD_API_KEY=

# DB 경로 (기본값 사용 권장)
DATABASE_URL=sqlite:///data/processed/realestate.db

# 로그 레벨
LOG_LEVEL=INFO
